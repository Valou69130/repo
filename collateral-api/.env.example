# Required — generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_with_64_byte_hex_secret
JWT_REFRESH_SECRET=replace_with_different_64_byte_hex_secret

# Server
PORT=3001
NODE_ENV=production

# CORS — comma-separated list of allowed origins
ALLOWED_ORIGINS=https://www.collateralos.app,http://localhost:5173

# Optional — defaults to ./data.db (or /tmp/collateral-demo.db on Vercel)
# COLLATERAL_DB_PATH=/app/data/collateral.db

# ── AI agent layer ────────────────────────────────────────────────────────────
# Disabled by default. Set AI_ENABLED=true and configure one provider below.
AI_ENABLED=false
AI_RATE_LIMIT_PER_HOUR=60

# Provider — 'bedrock' (EU-compliant, recommended) or 'anthropic' (direct API)
AI_PROVIDER=bedrock

# ── Option A: AWS Bedrock — EU-central-1 (Frankfurt) ─────────────────────────
# Data stays in the EU. AWS signs a GDPR DPA. Compliant with AI Act + BNR rules.
# IAM permissions required: bedrock:InvokeModel on the model ARNs below.
#
# Cross-region inference profile IDs — verify exact IDs in:
#   AWS Console → Bedrock → Cross-region inference → eu-central-1
AWS_REGION=eu-central-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# AWS_SESSION_TOKEN=   # only needed for temporary credentials / assumed roles

# Bedrock model IDs (eu-central-1 cross-region inference profiles)
BEDROCK_MODEL_COMPLEX=eu.anthropic.claude-opus-4-5-20251101-v1:0
BEDROCK_MODEL_ROUTINE=eu.anthropic.claude-sonnet-4-5-20251001-v1:0

# ── Option B: Direct Anthropic API — NOT recommended for production ───────────
# US-based, no EU data residency, no financial-services DPA.
# Suitable for local dev only. Switch to Bedrock before any client deployment.
# AI_PROVIDER=anthropic
# ANTHROPIC_API_KEY=
# AI_MODEL_COMPLEX=claude-opus-4-6
# AI_MODEL_ROUTINE=claude-sonnet-4-6
