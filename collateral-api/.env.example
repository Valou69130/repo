# Required — generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_with_64_byte_hex_secret
JWT_REFRESH_SECRET=replace_with_different_64_byte_hex_secret

# Server
PORT=3001
NODE_ENV=production

# CORS — comma-separated list of allowed origins
ALLOWED_ORIGINS=https://www.collateralos.app,http://localhost:5173

# Optional — defaults to ./data.db (or /tmp/collateral-demo.db on Vercel)
# COLLATERAL_DB_PATH=/app/data/collateral.db

# AI agent layer — disabled by default; system falls back to rule engine only
AI_ENABLED=false
ANTHROPIC_API_KEY=
ANTHROPIC_REGION=eu
AI_RATE_LIMIT_PER_HOUR=60
AI_MODEL_COMPLEX=claude-opus-4-6
AI_MODEL_ROUTINE=claude-sonnet-4-6
