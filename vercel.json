{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "npm install && npm install --prefix collateral-app && npm install --prefix collateral-api",
  "buildCommand": "cd collateral-app && npm run build",
  "outputDirectory": "collateral-app/dist",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/[...route]" }
  ]
}
